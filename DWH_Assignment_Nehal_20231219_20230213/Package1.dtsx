                    <arrayElement
                      dataType="System.String"><![CDATA[#region Namespaces
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
using System;
using System.Collections.Generic;
using System.Data;
using System.IO;
using System.Net;
using System.Web.Script.Serialization;
#endregion

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void CreateNewOutputRows()
    {
        try
        {
            // Enable TLS 1.2
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

            // REST API URL
            string url = "https://69be08c917c3d7d977910f4e.mockapi.io/us_air_quality/air_monitoring";

            HttpWebRequest request = (HttpWebRequest)WebRequest.Create(url);
            request.Method = "GET";

            using (HttpWebResponse response = (HttpWebResponse)request.GetResponse())
            using (StreamReader reader = new StreamReader(response.GetResponseStream()))
            {
                string json = reader.ReadToEnd();

                JavaScriptSerializer serializer = new JavaScriptSerializer();

                // Deserialize JSON
                var data = serializer.Deserialize<List<Dictionary<string, object>>>(json);

                foreach (var item in data)
                {
                    // =========================
                    // Check NULL values
                    // =========================

                    if (
                        item["id"] == null ||
                        item["location"] == null ||
                        item["timestamp"] == null ||
                        item["pm25"] == null ||
                        item["pm10"] == null
                    )
                    {
                        continue; // Skip invalid row
                    }

                    // =========================
                    // Read values safely
                    // =========================

                    string rawId = item["id"].ToString();
                    string city = item["location"].ToString();
                    string timestampStr = item["timestamp"].ToString();

                    // =========================
                    // Validate empty strings
                    // =========================

                    if (
                        string.IsNullOrWhiteSpace(rawId) ||
                        string.IsNullOrWhiteSpace(city) ||
                        string.IsNullOrWhiteSpace(timestampStr)
                    )
                    {
                        continue;
                    }

                    // =========================
                    // Keep sensor ID as-is
                    // Example: "U112" stays "U112"
                    // =========================

                    string sensorId = rawId;

                    // =========================
                    // Convert timestamp safely
                    // =========================

                    DateTime parsedTimestamp;

                    if (!DateTime.TryParse(timestampStr, out parsedTimestamp))
                    {
                        continue;
                    }

                    // =========================
                    // Convert pm25 safely
                    // =========================

                    double pm25;

                    if (!double.TryParse(item["pm25"].ToString(), out pm25))
                    {
                        continue;
                    }

                    // =========================
                    // Convert pm10 safely
                    // =========================

                    double pm10;

                    if (!double.TryParse(item["pm10"].ToString(), out pm10))
                    {
                        continue;
                    }

                    // =========================
                    // Skip negative pollution values
                    // =========================

                    if (pm25 < 0 || pm10 < 0)
                    {
                        continue;
                    }

                    // =========================
                    // Add VALID row only
                    // =========================

                    Output0Buffer.AddRow();

                    if (!sensorId.StartsWith("U"))
                    {
                        continue; // Skip rows that don't follow the expected API format
                    }

                    int sensorIdInt;
                    if (!int.TryParse(sensorId.Substring(1), out sensorIdInt))
                    {
                        continue; // Skip if the numeric part is invalid
                    }

                    // Later:
                    Output0Buffer.sensorid = sensorIdInt; // stores 112 from "U112"


                    Output0Buffer.city = city;
                    Output0Buffer.timestamp = parsedTimestamp;
                    Output0Buffer.pm25 = pm25;
                    Output0Buffer.pm10 = pm10;

                    // Source column
                    Output0Buffer.source = "API";
                }
            }
        }
        catch (Exception ex)
        {
            bool cancel;

            ComponentMetaData.FireError(
                0,
                "API Script",
                ex.Message,
                "",
                0,
                out cancel
            );

            throw;
        }
    }
}]]></arrayElement>
