                      dataType="System.String"><![CDATA[#region Namespaces
//using Microsoft.SqlServer.Dts.Pipeline.ScriptComponent;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
using System;
using System.Collections.Generic;
using System.Data;
using System.IO;
using System.Net;
using System.Web.Script.Serialization;  // For JavaScriptSerializer
#endregion

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void CreateNewOutputRows()
    {
        try
        {
            // FIX 1: Enable TLS 1.2 (MUST BE FIRST!)
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;

            // FIX 2: Remove the space at the end of the URL!
            string url = "https://69be08c917c3d7d977910f4e.mockapi.io/us_air_quality/air_monitoring";

            HttpWebRequest request = (HttpWebRequest)WebRequest.Create(url);
            request.Method = "GET";

            using (HttpWebResponse response = (HttpWebResponse)request.GetResponse())
            using (StreamReader reader = new StreamReader(response.GetResponseStream()))
            {
                string json = reader.ReadToEnd();

                JavaScriptSerializer serializer = new JavaScriptSerializer();

                // Deserialize into dynamic list
                var data = serializer.Deserialize<List<Dictionary<string, object>>>(json);

                foreach (var item in data)
                {
                    Output0Buffer.AddRow();

                    // sensor_id (id → INT extraction)
                    string rawId = item["id"] != null ? item["id"].ToString() : "0";
                    Output0Buffer.sensorid = int.Parse(rawId.Replace("U", ""));

                    // city (location cleanup)
                    string city = item["location"] != null ? item["location"].ToString() : "";
                    Output0Buffer.city = string.IsNullOrWhiteSpace(city) ? "Unknown" : city;

                    // timestamp
                    Output0Buffer.timestamp = item["timestamp"] != null
                        ? DateTime.Parse(item["timestamp"].ToString())
                        : DateTime.Now;

                    // pm25 cleaning
                    double pm25 = item["pm25"] != null ? Convert.ToDouble(item["pm25"]) : 0;
                    Output0Buffer.pm25 = pm25 < 0 ? 0 : pm25;

                    // pm10 cleaning
                    double pm10 = item["pm10"] != null ? Convert.ToDouble(item["pm10"]) : 0;
                    Output0Buffer.pm10 = pm10 < 0 ? 0 : pm10;

                    // source column
                    Output0Buffer.source = "API";
                }
            }
        }
        catch (Exception ex)
        {
            // This will show the error in SSIS execution results
            ComponentMetaData.FireError(0, "API Script", ex.Message, "", 0, out bool cancel);
            throw;  // Remove this line if you want package to continue despite errors
        }
    }
}]]></arrayElement>
